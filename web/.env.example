# Local Postgres (see repo root docker-compose.yml)
# DATABASE_URL=postgres://media:media@127.0.0.1:5432/media_pipeline
#
# Supabase (Vercel / production): Project Settings → Database → Connection string → URI
# Prefer the pooler (transaction mode, port 6543) for serverless when Supabase recommends it.
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
